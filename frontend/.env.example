# =============================================================================
# Frontend LOCAL (npm run dev na pasta frontend)
# =============================================================================
VITE_BACKEND_URL=http://localhost:8000
VITE_API_URL=/api

# =============================================================================
# Frontend no DOCKER (docker compose up frontend)
# As variáveis abaixo já estão no docker-compose.yml — não precisa duplicar no .env
# VITE_BACKEND_URL=http://nginx
# VITE_API_URL=/api
# =============================================================================

# Laravel Reverb (WebSocket) — browser sempre usa localhost (porta publicada)
VITE_REVERB_APP_KEY=mystique-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Só use URL absoluta se NÃO estiver com o dev server do Vite (ex.: build estático):
# VITE_API_URL=http://localhost:8000/api
